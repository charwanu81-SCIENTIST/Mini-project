#include <iostream>
using namespace std;


class Employee {
protected:
    string name;
    int id;
    float baseSalary;

public:
    Employee(string n, int i, float salary) {
        name = n;
        id = i;
        baseSalary = salary;
    }

    virtual float calculateSalary() {
        return baseSalary;
    }

    virtual void display() {
        cout << "\nEmployee ID: " << id;
        cout << "\nName: " << name;
        cout << "\nFinal Salary: " << calculateSalary() << endl;
    }
};


class Manager : public Employee {
private:
    float bonus;

public:
    Manager(string n, int i, float salary, float b)
        : Employee(n, i, salary) {
        bonus = b;
    }

    float calculateSalary() override {
        return baseSalary + bonus;
    }

    void display() override {
        cout << "\n--- Manager Details ---";
        Employee::display();
        cout << "Bonus: " << bonus << endl;
    }
};

class Developer : public Employee {
private:
    float overtimePay;

public:
    Developer(string n, int i, float salary, float ot)
        : Employee(n, i, salary) {
        overtimePay = ot;
    }

    float calculateSalary() override {
        return baseSalary + overtimePay;
    }

    void display() override {
        cout << "\n--- Developer Details ---";
        Employee::display();
        cout << "Overtime Pay: " << overtimePay << endl;
    }
};


int main() {
    int n;

    cout << "Enter number of employees: ";
    cin >> n;

    Employee* emp[n];  

    for (int i = 0; i < n; i++) {
        int choice, id;
        string name;
        float salary;

        cout << "\nEnter details for Employee " << i + 1 << endl;
        cout << "1. Manager\n2. Developer\nChoose type: ";
        cin >> choice;

        cout << "Enter ID: ";
        cin >> id;

        cout << "Enter Name: ";
        cin >> name;

        cout << "Enter Base Salary: ";
        cin >> salary;

        if (choice == 1) {
            float bonus;
            cout << "Enter Bonus: ";
            cin >> bonus;

            emp[i] = new Manager(name, id, salary, bonus);
        }
        else if (choice == 2) {
            float overtime;
            cout << "Enter Overtime Pay: ";
            cin >> overtime;

            emp[i] = new Developer(name, id, salary, overtime);
        }
        else {
            cout << "Invalid choice! Try again.\n";
            i--;
        }
    }

   
    cout << "\n\n===== Employee Details =====\n";
    for (int i = 0; i < n; i++) {
        emp[i]->display();
    }

    return 0;
}
